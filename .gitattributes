# Normalize text files and enforce LF line endings
* text=auto
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf

# Mark build artifacts and playground bundle to be excluded from archives
/dist/** export-ignore
/playground/dist-sdk.js export-ignore

# Docs and config should be included
README.md export-ignore

# Prevent large or binary files from being treated as text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
